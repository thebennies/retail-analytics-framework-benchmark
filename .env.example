# Database
POSTGRES_DB=benchmark
POSTGRES_USER=bench
POSTGRES_PASSWORD=bench

# PgBouncer
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_DEFAULT_POOL_SIZE=100
PGBOUNCER_MAX_CLIENT_CONN=15000

# Services (only affect host port mapping, services bind internally)
FASTAPI_PORT=8001
FASTIFY_PORT=8002
AXUM_PORT=8003

# FastAPI pool (set in docker-compose.yml, read by main.py)
# FASTAPI_POOL_MIN=5
# FASTAPI_POOL_MAX=25
# FASTAPI_WORKERS=4

# Fastify pool (set in docker-compose.yml, read by server.js)
# POOL_MAX=25
# POOL_MIN=5
# SERVICE_WORKERS=4

# Axum pool (set in docker-compose.yml, read by main.rs)
# POOL_MAX=100

# Generator (configured via CLI flags, not env vars)
# GENERATOR_TARGET_MONTH=auto       # --target-month flag
# GENERATOR_TOTAL_TRANSACTIONS=10000000  # hardcoded 10M

# Benchmark (only BENCH_ERROR_RATE_THRESHOLD is read by run-benchmark.sh)
# BENCH_WARMUP_SECONDS=10           # --warmup flag
# BENCH_DURATION_SECONDS=60         # --duration flag
# BENCH_COOLDOWN_SECONDS=15         # --cooldown flag
# BENCH_CONCURRENCY_LEVELS=10,50,100,500,1000,5000,10000  # --concurrency flag
BENCH_ERROR_RATE_THRESHOLD=0.05

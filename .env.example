# Database
POSTGRES_DB=benchmark
POSTGRES_USER=bench
POSTGRES_PASSWORD=bench

# PgBouncer
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_DEFAULT_POOL_SIZE=100
PGBOUNCER_MAX_CLIENT_CONN=15000

# Services
FASTAPI_PORT=8001
FASTIFY_PORT=8002
AXUM_PORT=8003
DASHBOARD_PORT=3000

# Generator
GENERATOR_TARGET_MONTH=auto       # 'auto' = previous calendar month, or YYYY-MM
GENERATOR_TOTAL_TRANSACTIONS=10000000

# Benchmark
BENCH_WARMUP_SECONDS=10
BENCH_DURATION_SECONDS=60
BENCH_COOLDOWN_SECONDS=15
BENCH_CONCURRENCY_LEVELS=10,50,100,500,1000,5000,10000
BENCH_ERROR_RATE_THRESHOLD=0.05
